views:
  - type: table
    name: 当日笔记
    filters:
      and:
        - file.ctime.format("YYYY-MM-DD") == this.file.name.slice(0, 10)
        - file.folder != "30-Time/34-Daily-日志"
        - file.folder != "30-Time/33-Weekly-每周"
        - file.folder != "40-storage/42-template-模板"
        - file.path != this.file.path
    order:
      - file.name
      - file.folder
      - file.ctime
    sort:
      - property: file.name
        direction: DESC
      - property: file.ctime
        direction: ASC
    columnSize:
      file.name: 363
      file.folder: 469
      file.ctime: 180
